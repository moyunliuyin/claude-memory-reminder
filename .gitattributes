# Force LF for shell scripts (cross-platform bash compatibility)
*.sh text eol=lf

# Force CRLF for PowerShell (Windows-native)
*.ps1 text eol=crlf

# Normalize other text files (auto per OS on checkout)
*.md      text
*.json    text
*.txt     text
LICENSE   text
.gitignore     text
.gitattributes text

# Explicit binary markers (future-proof)
*.png binary
*.jpg binary
*.ico binary
